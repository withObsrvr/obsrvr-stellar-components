{
  "name": "ducklake-sink",
  "version": "0.1.0",
  "type": "sink",
  "description": "Writes stellar.ledger.batch.v1 payloads into a DuckLake catalog through embedded DuckDB",
  "input_types": ["stellar.ledger.batch.v1"],
  "output_types": [],
  "config_schema": {
    "ducklake_catalog_path": { "env": "DUCKLAKE_CATALOG_PATH", "default": "ducklake/stellar.ducklake" },
    "ducklake_data_path": { "env": "DUCKLAKE_DATA_PATH", "default": "ducklake/data" },
    "ducklake_attach_name": { "env": "DUCKLAKE_ATTACH_NAME", "default": "stellar_lake" },
    "port": { "env": "PORT", "default": ":50052" },
    "health_port": { "env": "HEALTH_PORT", "default": "8089" },
    "flowctl_endpoint": { "env": "FLOWCTL_ENDPOINT" },
    "component_id": { "env": "COMPONENT_ID" }
  },
  "env_mapping": {
    "ducklake_catalog_path": "DUCKLAKE_CATALOG_PATH",
    "ducklake_data_path": "DUCKLAKE_DATA_PATH",
    "ducklake_attach_name": "DUCKLAKE_ATTACH_NAME",
    "port": "PORT",
    "health_port": "HEALTH_PORT",
    "flowctl_endpoint": "FLOWCTL_ENDPOINT",
    "component_id": "COMPONENT_ID"
  },
  "port": 50052,
  "health_port": 8089
}
