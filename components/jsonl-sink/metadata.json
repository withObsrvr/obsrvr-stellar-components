{
  "name": "jsonl-sink",
  "version": "0.1.0",
  "type": "sink",
  "description": "Writes stellar.ledger.batch.v1 payloads as protobuf JSON lines for debugging and fixtures",
  "input_types": ["stellar.ledger.batch.v1"],
  "output_types": [],
  "config_schema": {
    "jsonl_path": { "env": "JSONL_PATH", "default": "ledger_batches.jsonl" },
    "port": { "env": "PORT", "default": ":50052" },
    "health_port": { "env": "HEALTH_PORT", "default": "8089" },
    "flowctl_endpoint": { "env": "FLOWCTL_ENDPOINT" },
    "component_id": { "env": "COMPONENT_ID" }
  },
  "env_mapping": {
    "jsonl_path": "JSONL_PATH",
    "port": "PORT",
    "health_port": "HEALTH_PORT",
    "flowctl_endpoint": "FLOWCTL_ENDPOINT",
    "component_id": "COMPONENT_ID"
  },
  "port": 50052,
  "health_port": 8089
}
